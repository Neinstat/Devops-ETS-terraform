datadir="/var/lib/proxysql"

admin_variables=
{
    admin_credentials="kelompok2admin:Kelompok2devops!"
    mysql_ifaces="0.0.0.0:6032"
}

mysql_variables=
{
    threads=4
    max_connections=2048
    default_query_delay=0
    default_query_timeout=36000000
    interfaces="0.0.0.0:6033"
    monitor_username="kelompok2monitor"
    monitor_password="Kelompok2devops!"
}

mysql_servers=
(
    { address="10.0.1.20", port=3306, hostgroup=0, max_connections=100 },
    { address="10.0.1.21", port=3306, hostgroup=1, max_connections=100 }
)

mysql_users=
(
    { username="kelompok2user", password="Kelompok2devops!", default_hostgroup=0 }
)

mysql_query_rules=
(
    { rule_id=1, active=1, match_pattern="^SELECT", destination_hostgroup=1, apply=1 },
    { rule_id=2, active=1, match_pattern=".*", destination_hostgroup=0, apply=1 }
)